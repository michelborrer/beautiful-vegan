---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

const pageTitle = 'Cruelty-Free Brand Directory | Beautiful Vegan';
const pageDescription = 'Is your favorite brand truly cruelty-free? We research parent companies, certifications, and policies so you don\'t have to. Search our brand directory.';

const breadcrumbItems = [{ label: 'Brands' }];

const featuredBrands = [
  { name: 'The Ordinary', crueltyFree: true, vegan: 'mostly', parent: 'Estée Lauder', certified: 'PETA', featured: true },
  { name: 'CeraVe', crueltyFree: false, vegan: 'no', parent: "L'Oréal", certified: '', featured: true },
  { name: 'Versed', crueltyFree: true, vegan: 'yes', parent: 'Independent', certified: 'Leaping Bunny', featured: false },
  { name: 'Tower 28', crueltyFree: true, vegan: 'yes', parent: 'Independent', certified: 'Leaping Bunny', featured: false },
  { name: 'e.l.f.', crueltyFree: true, vegan: 'yes', parent: 'e.l.f. Beauty', certified: 'PETA, Leaping Bunny', featured: false },
  { name: 'Glossier', crueltyFree: true, vegan: 'mostly', parent: 'Independent', certified: 'Leaping Bunny', featured: false },
  { name: 'Drunk Elephant', crueltyFree: true, vegan: 'mostly', parent: 'Shiseido', certified: 'Leaping Bunny', featured: false },
  { name: 'Kiehl\'s', crueltyFree: false, vegan: 'no', parent: "L'Oréal", certified: '', featured: true },
  { name: 'Youth to the People', crueltyFree: true, vegan: 'yes', parent: 'L\'Oréal', certified: 'PETA', featured: false },
  { name: 'OSEA', crueltyFree: true, vegan: 'yes', parent: 'Independent', certified: 'PETA, Leaping Bunny', featured: false },
  { name: 'Fenty Beauty', crueltyFree: true, vegan: 'mostly', parent: 'LVMH', certified: 'PETA', featured: false },
  { name: 'Charlotte Tilbury', crueltyFree: true, vegan: 'mostly', parent: 'Puig', certified: 'Leaping Bunny', featured: false },
];

const recentlyUpdated = [
  { name: 'The Ordinary', date: 'May 2025', href: '/brands/is-the-ordinary-cruelty-free.html' },
  { name: 'CeraVe', date: 'April 2025', href: '/brands/is-cerave-cruelty-free.html' },
  { name: 'Kiehl\'s', date: 'April 2025', href: '/brands/is-kiehl-s-cruelty-free.html' },
];
---

<Layout title={pageTitle} description={pageDescription} canonical="/brands.html">
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  
  <div class="bg-stone-50">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={breadcrumbItems} />
    </div>
  </div>
  
  <section class="bg-sage-900 py-16 lg:py-24">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <h1 class="text-white mb-4">Cruelty-Free Brand Directory</h1>
        <p class="text-sage-200 text-lg leading-relaxed mb-8">
          We research every brand's parent company, certifications, and policies so you don't have to. Search 100+ brands and get clear answers.
        </p>
        <div class="relative max-w-md mx-auto">
          <input 
            type="text" 
            placeholder="Search brands..."
            class="w-full pl-12 pr-4 py-4 rounded-full bg-white/10 border border-sage-400/30 text-white placeholder:text-sage-300 outline-none focus:bg-white/20 transition-all"
          />
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 text-sage-300"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
      </div>
    </div>
  </section>
  
  <section class="bg-stone-50 section-padding">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <!-- Legend -->
      <div class="flex flex-wrap items-center justify-center gap-6 mb-10 text-sm">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-sage-500"></span>
          <span class="text-stone-600">Cruelty-Free</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-rose-500"></span>
          <span class="text-stone-600">Not Cruelty-Free</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-sage-200 border border-sage-400"></span>
          <span class="text-stone-600">100% Vegan</span>
        </div>
      </div>
      
      <!-- Featured -->
      <div class="mb-12">
        <h2 class="text-center mb-6">Featured Brands</h2>
        <div class="grid md:grid-cols-3 gap-4 max-w-4xl mx-auto">
          {featuredBrands.filter(b => b.featured).map(brand => (
            <a href={`/brands/is-${brand.name.toLowerCase().replace(/[^a-z]/g, '-')}-cruelty-free.html`} class="bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 block">
              <div class="flex items-center justify-between mb-3">
                <div class="w-12 h-12 bg-stone-100 rounded-full flex items-center justify-center font-playfair font-semibold text-stone-700">{brand.name.charAt(0)}</div>
                <div class="flex items-center gap-2">
                  {brand.crueltyFree ? (
                    <span class="px-2.5 py-1 bg-sage-100 text-sage-700 text-xs rounded-full font-medium">Cruelty-Free</span>
                  ) : (
                    <span class="px-2.5 py-1 bg-rose-100 text-rose-700 text-xs rounded-full font-medium">Not Cruelty-Free</span>
                  )}
                </div>
              </div>
              <h3 class="font-medium text-stone-900 mb-1">{brand.name}</h3>
              <p class="text-xs text-stone-500">Parent: {brand.parent}</p>
              {brand.certified && <p class="text-xs text-sage-600 mt-1">Certified: {brand.certified}</p>}
            </a>
          ))}
        </div>
      </div>
      
      <!-- All Brands -->
      <div>
        <h2 class="text-center mb-6">All Brands</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {featuredBrands.map(brand => (
            <a href={`/brands/is-${brand.name.toLowerCase().replace(/[^a-z]/g, '-')}-cruelty-free.html`} class="bg-white rounded-lg p-4 border border-stone-200 hover:border-sage-300 hover:shadow-sm transition-all flex items-center justify-between group">
              <div>
                <h4 class="font-medium text-stone-900 group-hover:text-sage-600 transition-colors">{brand.name}</h4>
                <p class="text-xs text-stone-500">{brand.vegan === 'yes' ? '100% Vegan' : brand.vegan === 'mostly' ? 'Mostly Vegan' : 'Not Vegan'}</p>
              </div>
              <span class={`w-3 h-3 rounded-full shrink-0 ${brand.crueltyFree ? 'bg-sage-500' : 'bg-rose-500'}`}></span>
            </a>
          ))}
        </div>
      </div>
      
      <!-- Recently Updated -->
      <div class="mt-12 max-w-md mx-auto">
        <h3 class="text-center mb-4 font-playfair text-xl">Recently Updated</h3>
        <div class="bg-white rounded-xl p-5 shadow-sm space-y-3">
          {recentlyUpdated.map(brand => (
            <a href={brand.href} class="flex items-center justify-between py-2 group">
              <span class="text-stone-700 group-hover:text-sage-600 transition-colors font-medium">{brand.name}</span>
              <span class="text-xs text-stone-400">{brand.date}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
  
  <NewsletterForm variant="section" />
  <Footer />
</Layout>
