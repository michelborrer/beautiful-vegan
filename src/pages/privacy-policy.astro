---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageTitle = 'Privacy Policy | Beautiful Vegan';
const pageDescription = 'Beautiful Vegan privacy policy, affiliate disclosure, and terms of use. We respect your privacy and are transparent about how we operate.';

const breadcrumbItems = [
  { label: 'Privacy Policy' },
];

const lastUpdated = 'June 18, 2026';
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  canonical="/privacy-policy"
>
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  
  <div class="bg-stone-50">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={breadcrumbItems} />
    </div>
  </div>
  
  <!-- Header -->
  <section class="bg-white py-12 lg:py-16 border-b border-stone-200">
    <div class="container-narrow px-4 sm:px-6 lg:px-8">
      <h1 class="mb-3">Privacy Policy & Legal</h1>
      <p class="text-stone-500">Last updated: {lastUpdated}</p>
    </div>
  </section>
  
  <!-- Content -->
  <article class="bg-white section-padding">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 prose prose-stone max-w-none">
      <h2>Privacy Policy</h2>
      <p>
        Beautiful Vegan ("we," "us," or "our") is committed to protecting your privacy. This Privacy Policy explains how we collect, use, and safeguard your information when you visit our website.
      </p>
      
      <h3>Information We Collect</h3>
      <p>
        <strong>Personal Information:</strong> We collect your email address when you voluntarily subscribe to our newsletter. We do not sell, trade, or rent your personal information to third parties.
      </p>
      <p>
        <strong>Non-Personal Information:</strong> We use privacy-friendly analytics (Plausible Analytics) that does not use cookies or collect personal data. This helps us understand which content is most helpful to our readers.
      </p>
      
      <h3>How We Use Your Information</h3>
      <ul>
        <li>To send our newsletter if you subscribe</li>
        <li>To respond to your inquiries</li>
        <li>To improve our website content and user experience</li>
      </ul>
      
      <h3>Cookies</h3>
      <p>
        We use minimal cookies. Our analytics platform is cookie-free and GDPR-compliant. If we add any cookie-based features in the future, we will implement a cookie consent banner and update this policy.
      </p>
      
      <h3>Third-Party Links</h3>
      <p>
        Our website contains affiliate links to retailers like Sephora, Ulta, and Amazon. When you click these links, a tracking cookie may be placed by the retailer (not by us) to credit us for the referral. This does not affect the price you pay.
      </p>
      
      <h3>Data Retention</h3>
      <p>
        Newsletter subscriber emails are retained until you unsubscribe. You may unsubscribe at any time by clicking the "unsubscribe" link in any email.
      </p>
      
      <h3>Your Rights</h3>
      <p>
        You have the right to access, correct, or delete your personal information. To exercise these rights, email us at hello@beautiful-vegan.com.
      </p>
      
      <h2 id="affiliate-disclosure">Affiliate Disclosure</h2>
      <p>
        <strong>Beautiful Vegan is a participant in affiliate marketing programs.</strong> This means that when you click on certain links on our website and make a purchase, we may earn a small commission at no additional cost to you.
      </p>
      <p>
        We are affiliated with programs including but not limited to:
      </p>
      <ul>
        <li>Amazon Associates</li>
        <li>Sephora Affiliate Program</li>
        <li>Ulta Beauty Affiliate Program</li>
        <li>Direct brand affiliate programs</li>
      </ul>
      <p>
        <strong>Our editorial integrity is non-negotiable.</strong> We only recommend products we have personally tested and genuinely believe in. Affiliate relationships do not influence our reviews, ratings, or recommendations. We disclose affiliate links on all applicable pages.
      </p>
      <p>
        This disclosure is provided in accordance with the Federal Trade Commission's 16 CFR, Part 255: "Guides Concerning the Use of Endorsements and Testimonials in Advertising."
      </p>
      
      <h2 id="terms">Terms of Use</h2>
      <p>
        By accessing and using Beautiful Vegan, you accept and agree to be bound by these Terms of Use. If you do not agree, please do not use our website.
      </p>
      
      <h3>Content Accuracy</h3>
      <p>
        We strive to provide accurate, up-to-date information. However, beauty product formulations, brand policies, and availability change frequently. We recommend verifying critical information (such as vegan status) directly with brands before purchasing.
      </p>
      
      <h3>Medical Disclaimer</h3>
      <p>
        The content on Beautiful Vegan is for informational purposes only and is not intended as medical advice. Always consult a dermatologist or healthcare provider for personalized skincare recommendations, especially if you have skin conditions or allergies.
      </p>
      
      <h3>Intellectual Property</h3>
      <p>
        All content on this website, including text, images, and graphics, is the property of Beautiful Vegan unless otherwise noted. Unauthorized reproduction or distribution is prohibited.
      </p>
      
      <h3>Contact</h3>
      <p>
        For questions about this Privacy Policy or our legal terms, contact us at <a href="mailto:hello@beautiful-vegan.com">hello@beautiful-vegan.com</a>.
      </p>
    </div>
  </article>
  
  <Footer />
</Layout>

<style>
  .prose h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 1.5rem; font-weight: 500; margin-top: 3rem; margin-bottom: 1rem; color: #4d4640; }
  @media (min-width: 1024px) { .prose h2 { font-size: 1.875rem; } }
  .prose h3 { font-family: 'Inter', system-ui, sans-serif; font-size: 1.125rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; color: #5f564c; }
  .prose p { color: #8a7d6e; line-height: 1.625; margin-bottom: 1rem; }
  .prose ul { list-style-type: disc; list-style-position: inside; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; color: #8a7d6e; }
  .prose a { color: #466846; text-decoration: underline; }
  .prose a:hover { color: #385238; }
</style>
