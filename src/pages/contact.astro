---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageTitle = 'Contact Us | Beautiful Vegan';
const pageDescription = 'Get in touch with Beautiful Vegan for general inquiries, brand partnerships, or press requests. We typically respond within 48 hours.';

const breadcrumbItems = [
  { label: 'Contact' },
];
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  canonical="/contact"
>
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  
  <div class="bg-stone-50">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={breadcrumbItems} />
    </div>
  </div>
  
  <!-- Hero -->
  <section class="bg-sage-900 py-16 lg:py-24">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h1 class="text-white mb-4 font-playfair text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight">Contact Us</h1>
        <p class="text-sage-200 text-lg leading-relaxed">
          Have a question, partnership idea, or just want to say hello? We'd love to hear from you.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Contact Section -->
  <section class="bg-white section-padding">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_400px] gap-12 lg:gap-16 max-w-5xl mx-auto">
        <!-- Form -->
        <div>
          <h2 class="mb-6">Send a Message</h2>
          <form class="space-y-5" action="/contact" method="POST">
            <div>
              <label for="name" class="block text-sm font-medium text-stone-700 mb-1.5">Name</label>
              <input 
                type="text" 
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg border border-stone-200 bg-stone-50 text-stone-900 outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-200 transition-all"
                placeholder="Your name"
              />
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-stone-700 mb-1.5">Email</label>
              <input 
                type="email" 
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-stone-200 bg-stone-50 text-stone-900 outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-200 transition-all"
                placeholder="you@example.com"
              />
            </div>
            
            <div>
              <label for="subject" class="block text-sm font-medium text-stone-700 mb-1.5">Subject</label>
              <select 
                id="subject"
                name="subject"
                required
                class="w-full px-4 py-3 rounded-lg border border-stone-200 bg-stone-50 text-stone-900 outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-200 transition-all"
              >
                <option value="">Select a topic</option>
                <option value="general">General Inquiry</option>
                <option value="brand">Brand Partnership</option>
                <option value="press">Press & Media</option>
              </select>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-stone-700 mb-1.5">Message</label>
              <textarea 
                id="message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-stone-200 bg-stone-50 text-stone-900 outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-200 transition-all resize-none"
                placeholder="How can we help?"
              ></textarea>
            </div>
            
            <button type="submit" class="btn-primary w-full sm:w-auto">
              Send Message
            </button>
          </form>
        </div>
        
        <!-- Info -->
        <div class="space-y-8">
          <div class="bg-stone-50 rounded-xl p-6">
            <h3 class="font-playfair text-xl font-medium mb-4">Response Time</h3>
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-sage-100 rounded-lg flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sage-600"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <p class="text-stone-700 text-sm">We typically respond within <strong class="text-stone-900">48 hours</strong> during business days.</p>
              </div>
            </div>
          </div>
          
          <div class="bg-stone-50 rounded-xl p-6">
            <h3 class="font-playfair text-xl font-medium mb-4">Email</h3>
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-sage-100 rounded-lg flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sage-600"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <a href="mailto:hello@beautiful-vegan.com" class="text-sage-600 hover:text-sage-700 font-medium text-sm">hello@beautiful-vegan.com</a>
              </div>
            </div>
          </div>
          
          <div class="bg-sage-900 rounded-xl p-6 text-center">
            <h4 class="font-playfair text-white text-lg font-medium mb-2">Brand Partnerships</h4>
            <p class="text-sage-300 text-sm mb-4">Interested in collaborating with Beautiful Vegan? We'd love to explore opportunities.</p>
            <a href="mailto:partnerships@beautiful-vegan.com" class="text-rose-400 hover:text-rose-300 font-medium text-sm transition-colors">
              partnerships@beautiful-vegan.com
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
