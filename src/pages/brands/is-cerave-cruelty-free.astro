---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const title = 'Is CeraVe Cruelty-Free? 2026 Update | Beautiful Vegan';
const description = 'CeraVe is one of the most popular skincare brands at the drugstore. But is it cruelty-free? We investigate.';

const breadcrumbItems = [
  { label: 'Brands', href: '/brands' },
  { label: 'CeraVe' },
];

const facts = [{"label": "Cruelty-Free", "value": "No", "class": "text-rose-600"}, {"label": "Vegan", "value": "No", "class": "text-rose-600"}, {"label": "Parent Company", "value": "L\'Oréal", "class": "text-stone-700"}, {"label": "Certifications", "value": "None", "class": "text-stone-500"}, {"label": "Sells in China", "value": "Yes", "class": "text-rose-600"}, {"label": "Price Range", "value": "$", "class": "text-stone-700"}, {"label": "Popular Products", "value": "Hydrating Cleanser, Moisturizing Cream, SA Cleanser", "class": "text-stone-700"}, {"label": "Alternatives", "value": "Versed, Cetaphil (similar price range)", "class": "text-sage-700"}];
const faqQuestions = [{"q": "Is CeraVe cruelty-free?", "a": "No. CeraVe is owned by L'Oréal, which sells in China where animal testing is required by law."}, {"q": "Is CeraVe vegan?", "a": "No. Many CeraVe products contain animal-derived ingredients like cholesterol."}, {"q": "Why do dermatologists recommend CeraVe?", "a": "CeraVe's ceramide-based formulas are effective and affordable. However, equally effective cruelty-free alternatives exist."}, {"q": "What is the best cruelty-free alternative to CeraVe?", "a": "Versed offers similar ceramide-rich formulas at a comparable price point, and they are fully cruelty-free."}];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Is CeraVe Cruelty-Free?',
  description,
  author: { '@type': 'Person', name: 'Casey Bloom' },
  publisher: { '@type': 'Organization', name: 'Beautiful Vegan', logo: { '@type': 'ImageObject', url: 'https://beautiful-vegan.com/images/logo.png' } },
  datePublished: '2025-05-01',
  dateModified: '2026-06-18',
  mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://beautiful-vegan.com/brands/is-cerave-cruelty-free' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqQuestions.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Layout title={title} description={description} canonical="/brands/is-cerave-cruelty-free" schema={schema} author="Casey Bloom" image="/images/category-skincare.jpg">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  <div class="bg-stone-50"><div class="container-main px-4 sm:px-6 lg:px-8"><Breadcrumb items={breadcrumbItems} /></div></div>

  <section class="bg-sage-900 py-16 lg:py-20">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-20 h-20 bg-stone-700 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="font-playfair text-3xl text-white font-bold">C</span>
      </div>
      <h1 class="text-white mb-4 font-playfair text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight">Is CeraVe Cruelty-Free?</h1>
      <div class="inline-flex items-center gap-3 bg-sage-800 rounded-full px-6 py-3 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-400"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
        <span class="text-sage-200 text-lg font-medium">No — CeraVe is NOT cruelty-free</span>
      </div>
      <p class="text-sage-300 leading-relaxed max-w-xl mx-auto">CeraVe's parent company L'Oréal tests on animals where required by law.</p>
    </div>
  </section>

  <article class="bg-white">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <!-- Facts Table -->
      <div class="bg-stone-50 rounded-xl overflow-hidden mb-10">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-stone-200">
            {facts.map(fact => (
              <tr>
                <td class="px-5 py-3 font-medium text-stone-700 w-2/5">{fact.label}</td>
                <td class="px-5 py-3 {fact.class} font-semibold">{fact.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>The Details</h2>
      <p class="text-stone-600 leading-relaxed mb-6">CeraVe is owned by L'Oréal, one of the largest beauty companies in the world. L'Oréal sells in mainland China, where animal testing is required by law for imported cosmetics. Because of this, CeraVe cannot be considered cruelty-free despite its popularity among dermatologists.</p>

      <p class="text-stone-600 leading-relaxed mb-6">CeraVe is not vegan either — some products contain cholesterol and other animal-derived ingredients. If you are looking for cruelty-free alternatives with similar ceramide-based formulas, consider <strong>Versed</strong> or <strong>Geologie</strong>.</p>

      <h2 class="mb-5">Frequently Asked Questions</h2>
      <div class="space-y-3 mb-10">
        {faqQuestions.map((faq, i) => (
          <details class="bg-stone-50 rounded-lg group" open={i === 0}>
            <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
              <span class="font-medium text-stone-900 pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-stone-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-4 pb-4"><p class="text-stone-600 leading-relaxed">{faq.a}</p></div>
          </details>
        ))}
      </div>

      <div class="border-t border-stone-200 pt-6">
        <p class="text-xs text-stone-400"><strong>Affiliate Disclosure:</strong> This post contains affiliate links. We earn a commission when you purchase through our links — at no extra cost to you.</p>
      </div>
    </div>
  </article>

  <NewsletterForm variant="section" />
  <Footer />
</Layout>
