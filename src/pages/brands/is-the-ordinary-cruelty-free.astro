---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AffiliateButton from '../../components/AffiliateButton.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const title = 'Is The Ordinary Cruelty-Free in 2025? | Beautiful Vegan';
const description = 'The Ordinary is beloved for affordable skincare, but is it truly cruelty-free? We investigate parent company Estée Lauder, certifications, and what it means for you.';

const breadcrumbItems = [
  { label: 'Brands', href: '/brands.html' },
  { label: 'The Ordinary' },
];

const quickFacts = [
  { label: 'Cruelty-Free', value: 'Yes', status: 'good' },
  { label: 'Vegan', value: 'Mostly', status: 'caution' },
  { label: 'Parent Company', value: 'Estée Lauder', status: 'bad' },
  { label: 'Certifications', value: 'Leaping Bunny, PETA', status: 'good' },
  { label: 'Sold in China', value: 'No', status: 'good' },
];

const bestProducts = [
  { name: 'Niacinamide 10% + Zinc 1%', price: '$6.00', vegan: true, category: 'Serum' },
  { name: 'Hyaluronic Acid 2% + B5', price: '$9.20', vegan: true, category: 'Serum' },
  { name: 'AHA 30% + BHA 2% Peeling Solution', price: '$8.70', vegan: true, category: 'Exfoliant' },
  { name: 'Retinol 1% in Squalane', price: '$8.10', vegan: true, category: 'Retinol' },
  { name: 'Natural Moisturizing Factors + HA', price: '$8.80', vegan: true, category: 'Moisturizer' },
];

const faqQuestions = [
  { q: 'Does The Ordinary test on animals?', a: 'No. The Ordinary does not test its finished products or ingredients on animals, and it does not ask others to test on its behalf. The brand is certified cruelty-free by both Leaping Bunny and PETA.' },
  { q: 'Is The Ordinary vegan?', a: 'Mostly. The majority of The Ordinary\'s products are vegan, but some contain animal-derived ingredients like honey derivatives or certain marine-based compounds. Each product page on their website clearly indicates vegan status.' },
  { q: 'Is The Ordinary sold in China?', a: 'No. The Ordinary does not sell in mainland China, which means it bypasses the animal testing requirements that apply to cosmetics sold in that market. This is a key reason it maintains its cruelty-free certifications.' },
  { q: 'Who owns The Ordinary?', a: 'The Ordinary is owned by DECIEM, which was acquired by Estée Lauder Companies in 2021. Estée Lauder is NOT cruelty-free as a company — they sell in markets that require animal testing. However, The Ordinary operates as a separate entity and maintains its own cruelty-free policies and certifications.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Is The Ordinary Cruelty-Free in 2025?',
  description,
  author: { '@type': 'Person', name: 'Casey Bloom' },
  publisher: { '@type': 'Organization', name: 'Beautiful Vegan', logo: { '@type': 'ImageObject', url: 'https://beautiful-vegan.com/images/logo.png' } },
  datePublished: '2025-04-28',
  dateModified: '2025-05-15',
  mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://beautiful-vegan.com/brands/is-the-ordinary-cruelty-free' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqQuestions.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://beautiful-vegan.com/' },
    { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://beautiful-vegan.com/brands' },
    { '@type': 'ListItem', position: 3, name: 'Is The Ordinary Cruelty-Free?' },
  ],
};
---

<Layout title={title} description={description} canonical="/brands/is-the-ordinary-cruelty-free" schema={schema} publishDate="2025-04-28" modifiedDate="2025-05-15" author="Casey Bloom" image="/images/articles/ordinary-brand.jpg">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  <div class="bg-stone-50"><div class="container-main px-4 sm:px-6 lg:px-8"><Breadcrumb items={breadcrumbItems} /></div></div>
  
  <!-- Direct Answer Hero -->
  <section class="bg-sage-900 py-16 lg:py-20">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-20 h-20 bg-stone-700 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="font-playfair text-3xl text-white font-bold">T</span>
      </div>
      <h1 class="text-white mb-4 font-playfair text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight">Is The Ordinary Cruelty-Free?</h1>
      <div class="inline-flex items-center gap-3 bg-sage-800 rounded-full px-6 py-3 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sage-400"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <span class="text-sage-200 text-lg font-medium">Yes — The Ordinary is cruelty-free</span>
      </div>
      <p class="text-sage-300 leading-relaxed max-w-xl mx-auto">
        The Ordinary does not test on animals and prohibits third-party testing.
        However, their parent company DECIEM was acquired by <strong class="text-white">Estée Lauder in 2021</strong>,
        which is <strong class="text-rose-300">NOT cruelty-free</strong>.
      </p>
    </div>
  </section>
  
  <article class="bg-white">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      
      <!-- Quick Facts -->
      <div class="grid sm:grid-cols-3 lg:grid-cols-5 gap-3 mb-10">
        {quickFacts.map(fact => (
          <div class={`rounded-xl p-4 text-center ${fact.status === 'good' ? 'bg-sage-50' : fact.status === 'caution' ? 'bg-yellow-50' : 'bg-rose-50'}`}>
            <p class="text-xs text-stone-500 uppercase font-medium mb-1">{fact.label}</p>
            <p class={`font-semibold ${fact.status === 'good' ? 'text-sage-700' : fact.status === 'caution' ? 'text-yellow-700' : 'text-rose-700'}`}>{fact.value}</p>
          </div>
        ))}
      </div>
      
      <h2>What We Know</h2>
      <p class="text-stone-600 leading-relaxed mb-4">The Ordinary burst onto the beauty scene in 2016 with a simple promise: clinical formulations at prices that do not make your eyes water. Under parent company DECIEM, it became a cult favorite. In 2021, <strong>Estée Lauder acquired a majority stake in DECIEM</strong>, and this is where things get complicated.</p>
      <p class="text-stone-600 leading-relaxed mb-4">Estée Lauder is not a cruelty-free company. They sell in mainland China, where imported cosmetics are required by law to undergo animal testing. While China has relaxed some regulations for domestically manufactured ordinary cosmetics, imported products still face testing requirements.</p>
      <p class="text-stone-600 leading-relaxed mb-8">However, The Ordinary itself maintains that it does not test on animals, nor does it ask others to test on its behalf. The brand holds both <strong>Leaping Bunny</strong> and <strong>PETA</strong> cruelty-free certifications. This dual certification is significant because Leaping Bunny requires independent auditing of the entire supply chain.</p>
      
      <h2>Vegan Status</h2>
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-5 mb-6">
        <div class="flex items-center gap-2 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-yellow-600"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          <span class="font-semibold text-yellow-800">Mostly Vegan</span>
        </div>
        <p class="text-yellow-700 text-sm leading-relaxed">Most of The Ordinary&apos;s products are vegan, but some contain animal-derived ingredients like honey derivatives or certain marine-based compounds. Always check the individual product page for vegan status.</p>
      </div>
      
      <h2>Best Cruelty-Free Products</h2>
      <p class="text-stone-600 leading-relaxed mb-6">Here are our top picks from The Ordinary&apos;s vegan product line, all tested and recommended by our team:</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
        {bestProducts.map(product => (
          <div class="border border-stone-200 rounded-xl p-4 hover:shadow-sm transition-all">
            <span class="text-xs text-stone-500 uppercase font-medium">{product.category}</span>
            <h4 class="font-medium text-stone-900 mt-1 mb-1">{product.name}</h4>
            <div class="flex items-center justify-between mt-2">
              <span class="text-rose-600 font-bold">{product.price}</span>
              <span class="text-xs bg-sage-100 text-sage-700 px-2 py-0.5 rounded-full">Vegan ✓</span>
            </div>
            <AffiliateButton label="View Product" />
          </div>
        ))}
      </div>
      
      <h2>Is The Ordinary Owned by a Non-Cruelty-Free Parent Company?</h2>
      <p class="text-stone-600 leading-relaxed mb-4">Yes — Estée Lauder acquired DECIEM (The Ordinary&apos;s parent company) in 2021. Estée Lauder is not cruelty-free because they sell in mainland China where animal testing is required by law for imported cosmetics.</p>
      <p class="text-stone-600 leading-relaxed mb-4">This creates a dilemma for many cruelty-free consumers. Some choose to boycott The Ordinary because profits ultimately flow to a parent company that participates in animal testing markets. Others argue that supporting The Ordinary sends a signal to Estée Lauder that cruelty-free brands are valuable and profitable, potentially encouraging the parent company to move toward cruelty-free practices.</p>
      <p class="text-stone-600 leading-relaxed mb-8">There is no universally correct answer — it is a personal choice. If avoiding parent company profits from animal testing is a priority for you, consider alternatives like <strong>Versed</strong>, <strong>The Inkey List</strong>, or <strong>Good Molecules</strong>, which offer similar affordable, ingredient-focused skincare without the parent company complication.</p>
      
      <!-- FAQ -->
      <h2 class="mb-5">Frequently Asked Questions</h2>
      <div class="space-y-3 mb-10">
        {faqQuestions.map((faq, i) => (
          <details class="bg-stone-50 rounded-lg group" open={i === 0}>
            <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
              <span class="font-medium text-stone-900 pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-stone-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-4 pb-4"><p class="text-stone-600 leading-relaxed">{faq.a}</p></div>
          </details>
        ))}
      </div>
      
      <div class="border-t border-stone-200 pt-6">
        <p class="text-xs text-stone-400"><strong>Affiliate Disclosure:</strong> This post contains affiliate links. We earn a commission when you purchase through our links — at no extra cost to you.</p>
      </div>
    </div>
  </article>
  
  <NewsletterForm variant="section" />
  <Footer />
</Layout>
