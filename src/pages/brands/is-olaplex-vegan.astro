---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const title = 'Is Olaplex Cruelty-Free? 2026 Update | Beautiful Vegan';
const description = 'Olaplex revolutionized hair repair. But is it cruelty-free and vegan? We break it down.';

const breadcrumbItems = [
  { label: 'Brands', href: '/brands' },
  { label: 'Olaplex' },
];

const facts = [{"label": "Cruelty-Free", "value": "Yes", "class": "text-sage-700"}, {"label": "Vegan", "value": "Mostly", "class": "text-yellow-700"}, {"label": "Parent Company", "value": "Independent (public)", "class": "text-stone-700"}, {"label": "Certifications", "value": "PETA", "class": "text-sage-700"}, {"label": "Sells in China", "value": "No", "class": "text-sage-700"}, {"label": "Price Range", "value": "$$$", "class": "text-stone-700"}, {"label": "Popular Products", "value": "No. 3 Hair Perfector, No. 7 Bonding Oil", "class": "text-stone-700"}, {"label": "Alternatives", "value": "Amika, Briogeo", "class": "text-sage-700"}];
const faqQuestions = [{"q": "Is Olaplex cruelty-free?", "a": "Yes. Olaplex is PETA-certified and does not test on animals."}, {"q": "Is Olaplex vegan?", "a": "Mostly, but not entirely. Some products contain non-vegan ingredients."}, {"q": "Which Olaplex products are vegan?", "a": "Check Olaplex's website for the most current list, as formulations change."}, {"q": "What is a vegan alternative to Olaplex?", "a": "Amika's The Kure line and Briogeo's Don't Despair, Repair! line are both fully vegan and cruelty-free."}];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Is Olaplex Cruelty-Free?',
  description,
  author: { '@type': 'Person', name: 'Casey Bloom' },
  publisher: { '@type': 'Organization', name: 'Beautiful Vegan', logo: { '@type': 'ImageObject', url: 'https://beautiful-vegan.com/images/logo.png' } },
  datePublished: '2025-05-01',
  dateModified: '2026-06-18',
  mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://beautiful-vegan.com/brands/is-olaplex-vegan' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqQuestions.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Layout title={title} description={description} canonical="/brands/is-olaplex-vegan" schema={schema} author="Casey Bloom" image="/images/category-haircare.jpg">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  <div class="bg-stone-50"><div class="container-main px-4 sm:px-6 lg:px-8"><Breadcrumb items={breadcrumbItems} /></div></div>

  <section class="bg-sage-900 py-16 lg:py-20">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-20 h-20 bg-stone-700 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="font-playfair text-3xl text-white font-bold">O</span>
      </div>
      <h1 class="text-white mb-4 font-playfair text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight">Is Olaplex Cruelty-Free?</h1>
      <div class="inline-flex items-center gap-3 bg-sage-800 rounded-full px-6 py-3 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sage-400"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <span class="text-sage-200 text-lg font-medium">It's Complicated — Olaplex is cruelty-free but NOT fully vegan</span>
      </div>
      <p class="text-sage-300 leading-relaxed max-w-xl mx-auto">Olaplex does not test on animals, but some products contain non-vegan ingredients.</p>
    </div>
  </section>

  <article class="bg-white">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <!-- Facts Table -->
      <div class="bg-stone-50 rounded-xl overflow-hidden mb-10">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-stone-200">
            {facts.map(fact => (
              <tr>
                <td class="px-5 py-3 font-medium text-stone-700 w-2/5">{fact.label}</td>
                <td class="px-5 py-3 {fact.class} font-semibold">{fact.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>The Details</h2>
      <p class="text-stone-600 leading-relaxed mb-6">Olaplex is cruelty-free — they do not test on animals and are PETA-certified. However, not all Olaplex products are vegan. Some contain ingredients derived from animal sources. The brand has stated they are working toward becoming fully vegan, but they are not there yet.</p>

      <p class="text-stone-600 leading-relaxed mb-6">If you want a fully vegan alternative to Olaplex, <strong>Amika</strong> and <strong>Briogeo</strong> offer bond-repairing hair treatments that are both cruelty-free and 100% vegan. Amika's The Kure line is particularly effective for damaged hair.</p>

      <h2 class="mb-5">Frequently Asked Questions</h2>
      <div class="space-y-3 mb-10">
        {faqQuestions.map((faq, i) => (
          <details class="bg-stone-50 rounded-lg group" open={i === 0}>
            <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
              <span class="font-medium text-stone-900 pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-stone-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-4 pb-4"><p class="text-stone-600 leading-relaxed">{faq.a}</p></div>
          </details>
        ))}
      </div>

      <div class="border-t border-stone-200 pt-6">
        <p class="text-xs text-stone-400"><strong>Affiliate Disclosure:</strong> This post contains affiliate links. We earn a commission when you purchase through our links — at no extra cost to you.</p>
      </div>
    </div>
  </article>

  <NewsletterForm variant="section" />
  <Footer />
</Layout>
