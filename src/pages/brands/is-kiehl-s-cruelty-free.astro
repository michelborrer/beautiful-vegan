---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const title = 'Is Kiehl\'s Cruelty-Free? 2026 Update | Beautiful Vegan';
const description = 'Kiehl\'s has been a skincare staple for decades. But is it cruelty-free in 2026? We break down the facts.';

const breadcrumbItems = [
  { label: 'Brands', href: '/brands' },
  { label: 'Kiehl\'s' },
];

const facts = [{"label": "Cruelty-Free", "value": "No", "class": "text-rose-600"}, {"label": "Vegan", "value": "No", "class": "text-rose-600"}, {"label": "Parent Company", "value": "L\'Oréal", "class": "text-stone-700"}, {"label": "Certifications", "value": "None", "class": "text-stone-500"}, {"label": "Sells in China", "value": "Yes", "class": "text-rose-600"}, {"label": "Price Range", "value": "$$$", "class": "text-stone-700"}, {"label": "Popular Products", "value": "Midnight Recovery Concentrate, Ultra Facial Cream", "class": "text-stone-700"}, {"label": "Alternatives", "value": "Youth to the People, OSEA", "class": "text-sage-700"}];
const faqQuestions = [{"q": "Is Kiehl's cruelty-free?", "a": "No. Kiehl's is owned by L'Oréal and sells in China."}, {"q": "Does Kiehl's test on animals?", "a": "Kiehl's does not test on animals directly, but their parent company L'Oréal does in markets where required by law."}, {"q": "Is Kiehl's vegan?", "a": "Some products are vegan, but the brand is not fully vegan."}, {"q": "What is a good cruelty-free alternative to Kiehl's?", "a": "Youth to the People offers similar high-quality, science-backed skincare that is fully cruelty-free and mostly vegan."}];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Is Kiehl\'s Cruelty-Free?',
  description,
  author: { '@type': 'Person', name: 'Casey Bloom' },
  publisher: { '@type': 'Organization', name: 'Beautiful Vegan', logo: { '@type': 'ImageObject', url: 'https://beautiful-vegan.com/images/logo.png' } },
  datePublished: '2025-05-01',
  dateModified: '2026-06-18',
  mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://beautiful-vegan.com/brands/is-kiehl-s-cruelty-free' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqQuestions.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Layout title={title} description={description} canonical="/brands/is-kiehl-s-cruelty-free" schema={schema} author="Casey Bloom" image="/images/category-skincare.jpg">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  <div class="bg-stone-50"><div class="container-main px-4 sm:px-6 lg:px-8"><Breadcrumb items={breadcrumbItems} /></div></div>

  <section class="bg-sage-900 py-16 lg:py-20">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-20 h-20 bg-stone-700 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="font-playfair text-3xl text-white font-bold">K</span>
      </div>
      <h1 class="text-white mb-4 font-playfair text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight">Is Kiehl's Cruelty-Free?</h1>
      <div class="inline-flex items-center gap-3 bg-sage-800 rounded-full px-6 py-3 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-400"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
        <span class="text-sage-200 text-lg font-medium">No — Kiehl's is NOT cruelty-free</span>
      </div>
      <p class="text-sage-300 leading-relaxed max-w-xl mx-auto">Kiehl's is owned by L'Oréal and sells in China, where animal testing is required.</p>
    </div>
  </section>

  <article class="bg-white">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <!-- Facts Table -->
      <div class="bg-stone-50 rounded-xl overflow-hidden mb-10">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-stone-200">
            {facts.map(fact => (
              <tr>
                <td class="px-5 py-3 font-medium text-stone-700 w-2/5">{fact.label}</td>
                <td class="px-5 py-3 {fact.class} font-semibold">{fact.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>The Details</h2>
      <p class="text-stone-600 leading-relaxed mb-6">Kiehl's was founded in 1851 as an old-world apothecary in New York City. While their products are beloved for their quality and heritage, the brand is owned by L'Oréal and sells in mainland China, which means they are not cruelty-free.</p>

      <p class="text-stone-600 leading-relaxed mb-6">Kiehl's does offer some vegan products, but the brand as a whole is not vegan. For cruelty-free alternatives with similar apothecary-style formulations, <strong>Youth to the People</strong> and <strong>OSEA</strong> are excellent choices.</p>

      <h2 class="mb-5">Frequently Asked Questions</h2>
      <div class="space-y-3 mb-10">
        {faqQuestions.map((faq, i) => (
          <details class="bg-stone-50 rounded-lg group" open={i === 0}>
            <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
              <span class="font-medium text-stone-900 pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-stone-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-4 pb-4"><p class="text-stone-600 leading-relaxed">{faq.a}</p></div>
          </details>
        ))}
      </div>

      <div class="border-t border-stone-200 pt-6">
        <p class="text-xs text-stone-400"><strong>Affiliate Disclosure:</strong> This post contains affiliate links. We earn a commission when you purchase through our links — at no extra cost to you.</p>
      </div>
    </div>
  </article>

  <NewsletterForm variant="section" />
  <Footer />
</Layout>
