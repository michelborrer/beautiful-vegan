---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import AuthorBox from '../../../components/AuthorBox.astro';
import AffiliateButton from '../../../components/AffiliateButton.astro';
import NewsletterForm from '../../../components/NewsletterForm.astro';

const title = '5 Vegan Shampoo Bars That Replace Your Bottle | Beautiful Vegan';
const description = 'These concentrated bars clean better than liquid shampoo, last 3x longer, and come with zero plastic packaging. Our top 5 picks after 6 weeks of testing.';

const breadcrumbItems = [
  { label: 'Reviews', href: '/reviews/haircare' },
  { label: 'Haircare', href: '/reviews/haircare' },
  { label: 'Shampoo Bars' },
];

const products = [
  { rank: 1, name: 'Coconut Rice Curl Shampoo Bar', brand: 'Viori', price: '$18.00', rating: '4.5', bestFor: 'Curly Hair', pros: ['Made with Longsheng rice water', 'Defines curls beautifully', 'One bar lasts 60+ washes', 'Zero plastic packaging'], cons: ['Premium price', 'Takes a few washes to adjust'], verdict: 'The best shampoo bar we tested for curly hair. The rice water base adds slip and definition that our curl-pattern testers loved. One bar replaced two full bottles of liquid shampoo.' },
  { rank: 2, name: 'Lavender Tea Tree Shampoo Bar', brand: 'Ethique', price: '$15.00', rating: '4.0', bestFor: 'Oily Scalp', pros: ['Deep cleansing without stripping', 'Tea tree controls oil', 'One bar = 3 bottles', 'Compostable packaging'], cons: ['Can be drying on ends', 'Strong herbal scent'], verdict: 'If you struggle with oily roots, start here. The tea tree oil keeps scalp oil in check while lavender takes the edge off any irritation. Our oily-scalp testers went from washing daily to every other day within two weeks — the strong herbal scent is the only thing dividing opinion.' },
  { rank: 3, name: 'Rosemary Mint Shampoo Bar', brand: 'HiBar', price: '$13.99', rating: '4.0', bestFor: 'Fine Hair', pros: ['Adds volume to fine hair', 'Unique ergonomic shape', 'Color-safe formula', 'Easy to hold when wet'], cons: ['Shape can be awkward in small showers', 'Less lather than liquid'], verdict: 'HiBar solved the biggest shampoo bar problem — the slippery soap issue. The ergonomic shape is genuinely easier to hold, and the formula adds noticeable volume to fine hair without weighing it down.' },
  { rank: 4, name: 'Moisturizing Shampoo Bar', brand: 'Basd', price: '$12.00', rating: '3.5', bestFor: 'Dry Hair', pros: ['Coconut oil and shea butter base', 'Incredibly moisturizing', 'Budget-friendly', 'Gentle enough for color-treated hair'], cons: ['Can feel heavy on fine hair', 'Less lather than others'], verdict: 'For dry, damaged, or color-treated hair, this is the most nourishing bar we tested. The coconut oil and shea butter combination leaves hair soft and manageable — no conditioner needed for some hair types.' },
  { rank: 5, name: 'Sweet & Sassy Shampoo Bar', brand: 'Tangie', price: '$11.95', rating: '4.0', bestFor: 'All Hair Types', pros: ['Works on all hair types', 'Long-lasting formula', 'Subtle pleasant scent', 'Great lather for a bar'], cons: ['Basic formula without actives', 'Scent might be too subtle for some'], verdict: 'The most versatile shampoo bar in our test. It performed well across all hair types, produced a satisfying lather, and lasted the longest — nearly 70 washes in our testing. If you want one bar that works for everyone in the household, this is it.' },
];

const faqQuestions = [
  { q: 'Do shampoo bars actually clean as well as liquid shampoo?', a: 'Yes — when formulated correctly. Shampoo bars use the same cleansing agents (surfactants) as liquid shampoos, just in a solid, concentrated form. The key is finding a bar with quality surfactants like sodium cocoyl isethionate (from coconut) rather than harsh sulfates. All the bars we recommend clean effectively without stripping.' },
  { q: 'How long does a shampoo bar last?', a: 'A quality shampoo bar typically lasts 50-80 washes, equivalent to 2-3 bottles of liquid shampoo. To maximize lifespan, store the bar on a soap dish that allows drainage so it dries completely between uses. Never leave it sitting in a puddle of water.' },
  { q: 'Is there a transition period when switching to shampoo bars?', a: 'Some people experience a 1-3 week adjustment period as their scalp recalibrates oil production. Traditional liquid shampoos often contain silicones that coat the hair, and it takes a few washes for these to fully clear. Stick with it — most people find their hair looks and feels better after the transition.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: '5 Vegan Shampoo Bars That Replace Your Bottle',
  description,
  image: 'https://beautiful-vegan.com/images/articles/shampoo-bar.jpg',
  author: { '@type': 'Person', name: 'Casey Bloom' },
  publisher: { '@type': 'Organization', name: 'Beautiful Vegan', logo: { '@type': 'ImageObject', url: 'https://beautiful-vegan.com/images/logo.png' } },
  datePublished: '2025-05-05',
  dateModified: '2026-06-18',
  mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://beautiful-vegan.com/reviews/haircare/best-vegan-shampoo-bars' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://beautiful-vegan.com/' },
    { '@type': 'ListItem', position: 2, name: 'Haircare', item: 'https://beautiful-vegan.com/reviews/haircare' },
    { '@type': 'ListItem', position: 3, name: 'Shampoo Bars' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqQuestions.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Layout title={title} description={description} image="/images/articles/shampoo-bar.jpg" type="article" canonical="/reviews/haircare/best-vegan-shampoo-bars" schema={schema} publishDate="2025-05-05" modifiedDate="2026-06-18" author="Casey Bloom">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  <div class="bg-stone-50"><div class="container-main px-4 sm:px-6 lg:px-8"><Breadcrumb items={breadcrumbItems} /></div></div>
  
  <header class="bg-white py-8"><div class="container-narrow px-4 sm:px-6 lg:px-8">
    <span class="tag-sage mb-4 inline-block">Haircare</span>
    <h1 class="mb-4 font-playfair text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight">5 Vegan Shampoo Bars That Replace Your Bottle</h1>
    <div class="flex flex-wrap items-center gap-3 text-sm text-stone-500">
      <div class="flex items-center gap-2"><div class="w-8 h-8 rounded-full bg-sage-100 flex items-center justify-center text-sage-600 text-xs font-semibold">CB</div><span>By <strong class="text-stone-700">Casey Bloom</strong></span></div>
      <span class="text-stone-300">|</span><span>Updated June 18, 2026</span><span class="text-stone-300">|</span><span>6 min read</span>
    </div>
  </div></header>
  
  <div class="container-main px-4 sm:px-6 lg:px-8"><img src="/images/articles/shampoo-bar.jpg" alt="Vegan shampoo bars on wooden surface with eucalyptus" class="w-full aspect-video object-cover rounded-xl" loading="eager" width="1200" height="675" /></div>
  
  <div class="bg-white">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 py-12">
      <div class="text-lg text-stone-600 mb-8">
        <p class="text-xl leading-relaxed"><strong class="text-stone-900">The average person uses 10-15 bottles of shampoo per year.</strong> That is a lot of plastic for something that is mostly water.</p>
        <p class="mt-4">Shampoo bars eliminate the plastic entirely. They are concentrated (no water added), last 2-3x longer than a bottle, and travel like a dream. We tested 12 bars over 6 weeks on straight, wavy, curly, and coily hair. These 5 actually performed — and in some cases, outperformed their liquid counterparts.</p>
      </div>
      
      <h2>The Winners</h2>
      <div class="space-y-6">
        {products.map(p => (
          <div class="border border-stone-200 rounded-xl p-5 lg:p-6">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-14 h-14 bg-sage-500 text-white rounded-xl flex items-center justify-center font-playfair font-bold text-xl shrink-0">#{p.rank}</div>
              <div class="flex-1">
                <h3 class="font-playfair text-xl font-medium">{p.brand} {p.name}</h3>
                <div class="flex items-center gap-3 mt-1">
                  <span class="text-rose-600 font-bold">{p.price}</span>
                  <span class="text-xs bg-sage-100 text-sage-700 px-2 py-0.5 rounded-full">{p.bestFor}</span>
                </div>
              </div>
            </div>
            <div class="grid sm:grid-cols-2 gap-4 mb-4">
              <div><p class="text-xs font-semibold text-sage-700 uppercase mb-2">Pros</p><ul class="space-y-1">{p.pros.map(pro => <li class="flex items-start gap-2 text-sm text-stone-600"><svg class="w-4 h-4 text-sage-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{pro}</li>)}</ul></div>
              <div><p class="text-xs font-semibold text-rose-700 uppercase mb-2">Cons</p><ul class="space-y-1">{p.cons.map(con => <li class="flex items-start gap-2 text-sm text-stone-600"><svg class="w-4 h-4 text-rose-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>{con}</li>)}</ul></div>
            </div>
            <div class="bg-stone-50 rounded-lg p-4 mb-4"><p class="text-sm text-stone-600 italic">{p.verdict}</p></div>
            <AffiliateButton />
          </div>
        ))}
      </div>
      
      <h2 class="mt-12 mb-4">How to Use a Shampoo Bar</h2>
      <div class="bg-stone-50 rounded-xl p-6 mb-8">
        <ol class="space-y-3 text-stone-700">
          <li class="flex gap-3"><span class="w-6 h-6 bg-sage-500 text-white rounded-full flex items-center justify-center text-xs font-bold shrink-0">1</span><span><strong>Wet your hair thoroughly</strong> — the bar needs water to activate.</span></li>
          <li class="flex gap-3"><span class="w-6 h-6 bg-sage-500 text-white rounded-full flex items-center justify-center text-xs font-bold shrink-0">2</span><span><strong>Rub the bar</strong> directly on your scalp in a few strokes, or lather in your hands first.</span></li>
          <li class="flex gap-3"><span class="w-6 h-6 bg-sage-500 text-white rounded-full flex items-center justify-center text-xs font-bold shrink-0">3</span><span><strong>Massage into scalp</strong> with your fingertips — work up a good lather.</span></li>
          <li class="flex gap-3"><span class="w-6 h-6 bg-sage-500 text-white rounded-full flex items-center justify-center text-xs font-bold shrink-0">4</span><span><strong>Rinse thoroughly.</strong> Some bars benefit from an apple cider vinegar rinse (1 tbsp in 1 cup water) once a week.</span></li>
          <li class="flex gap-3"><span class="w-6 h-6 bg-sage-500 text-white rounded-full flex items-center justify-center text-xs font-bold shrink-0">5</span><span><strong>Store the bar</strong> on a draining soap dish to keep it dry between uses.</span></li>
        </ol>
      </div>
      
      <h2 class="mb-5">Frequently Asked Questions</h2>
      <div class="space-y-3 mb-10">
        {faqQuestions.map((faq, i) => (
          <details class="bg-stone-50 rounded-lg group" open={i === 0}>
            <summary class="flex items-center justify-between p-4 cursor-pointer list-none"><span class="font-medium text-stone-900 pr-4">{faq.q}</span><svg class="w-5 h-5 text-stone-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></summary>
            <div class="px-4 pb-4"><p class="text-stone-600 leading-relaxed">{faq.a}</p></div>
          </details>
        ))}
      </div>
      
      <div class="border-t border-stone-200 pt-6"><p class="text-xs text-stone-400"><strong>Affiliate Disclosure:</strong> This post contains affiliate links. We earn a commission when you purchase through our links — at no extra cost to you.</p></div>
      <AuthorBox />
    </div>
  </div>
  
  <NewsletterForm variant="section" />
  <Footer />
</Layout>
