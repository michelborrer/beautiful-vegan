---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const pageTitle = 'Vegan Haircare Reviews | Beautiful Vegan';
const pageDescription = 'Plant-powered shampoos, conditioners, and treatments for healthy hair. All vegan, all cruelty-free, tested on real hair.';

const breadcrumbItems = [
  { label: 'Reviews', href: '/reviews/haircare' },
  { label: 'Haircare' },
];

const articles = [
  {
    title: '5 Vegan Shampoo Bars That Replace Your Bottle',
    excerpt: 'These concentrated bars clean better than liquid shampoo, last 3x longer, and come with zero plastic packaging.',
    image: '/images/articles/shampoo-bar.jpg',
    category: 'Shampoo',
    categoryHref: '/reviews/haircare',
    href: '/reviews/haircare/best-vegan-shampoo-bars',
    date: 'May 5, 2026',
    readTime: '6 min read',
    rating: '4.5',
  },
  {
    title: 'Best Vegan Hair Oils for Dry, Damaged Hair',
    excerpt: 'Bring your hair back to life with these deeply nourishing plant-based oils. We tested 10 and found 4 that genuinely repair split ends.',
    image: '/images/articles/hair-oil.jpg',
    category: 'Hair Oil',
    categoryHref: '/reviews/haircare',
    href: '/reviews/haircare/best-vegan-hair-oils',
    date: 'April 28, 2026',
    readTime: '8 min read',
    rating: '4.7',
  },
  {
    title: 'Best Vegan Conditioners for Curly Hair',
    excerpt: 'Curly hair needs extra moisture and definition. These 5 vegan conditioners deliver both without weighing down your curls.',
    image: '/images/articles/moisturizer-article.jpg',
    category: 'Conditioner',
    categoryHref: '/reviews/haircare',
    href: '/reviews/haircare/best-vegan-conditioners-curly-hair',
    date: 'April 20, 2026',
    readTime: '5 min read',
    rating: '4.3',
  },
];

const sidebarArticles = [
  { title: 'Vegan Hair Dye Guide: Safe, Cruelty-Free Color', href: '/reviews/haircare/vegan-hair-dye-guide' },
  { title: 'Best Vegan Conditioners for Curly Hair', href: '/reviews/haircare/best-vegan-conditioners-curly-hair' },
  { title: 'Is Olaplex Actually Vegan?', href: '/brands/is-olaplex-vegan' },
];

const relatedIngredients = [
  { name: 'Coconut Oil', href: '/ingredients/coconut-oil-skin' },
  { name: 'Jojoba Oil', href: '/ingredients/jojoba-oil-benefits' },
  { name: 'Aloe Vera', href: '/ingredients/aloe-vera-skin-benefits' },
];
---

<Layout title={pageTitle} description={pageDescription} canonical="/reviews/haircare">
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  
  <div class="bg-stone-50">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={breadcrumbItems} />
    </div>
  </div>
  
  <section class="relative bg-sage-900">
    <div class="absolute inset-0">
      <img src="/images/category-haircare.jpg" alt="Vegan haircare products with rosemary" class="w-full h-full object-cover opacity-30" loading="eager" width="1200" height="500" />
      <div class="absolute inset-0 bg-gradient-to-r from-sage-900/90 to-sage-900/50"></div>
    </div>
    <div class="container-main px-4 sm:px-6 lg:px-8 relative z-10 py-16 lg:py-24">
      <div class="max-w-2xl">
        <h1 class="text-white mb-4">Vegan Haircare Reviews</h1>
        <p class="text-sage-200 text-lg leading-relaxed">
          Nourish your hair with plant-powered shampoos, conditioners, and treatments. From scalp care to styling, we've got your hair covered.
        </p>
      </div>
    </div>
  </section>
  
  <section class="bg-stone-50 section-padding">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_320px] gap-10">
        <div>
          <div class="flex flex-wrap items-center gap-3 mb-8">
            <span class="text-sm text-stone-500">Filter:</span>
            <a href="/reviews/haircare" class="px-4 py-1.5 bg-sage-500 text-white text-sm rounded-full font-medium">All</a>
            <a href="/reviews/haircare/best-vegan-shampoo-bars" class="px-4 py-1.5 bg-white text-stone-600 text-sm rounded-full font-medium border border-stone-200 hover:border-sage-300 transition-colors">Shampoo</a>
            <a href="/reviews/haircare/best-vegan-conditioners-curly-hair" class="px-4 py-1.5 bg-white text-stone-600 text-sm rounded-full font-medium border border-stone-200 hover:border-sage-300 transition-colors">Conditioner</a>
            <a href="/reviews/haircare/best-vegan-hair-oils" class="px-4 py-1.5 bg-white text-stone-600 text-sm rounded-full font-medium border border-stone-200 hover:border-sage-300 transition-colors">Hair Oil</a>
            <span class="px-4 py-1.5 bg-white text-stone-400 text-sm rounded-full font-medium border border-stone-200 opacity-50 cursor-not-allowed" title="Coming soon">Styling</span>
          </div>
          
          <div class="grid sm:grid-cols-2 gap-6">
            {articles.map(article => <ArticleCard {...article} />)}
          </div>
          
          <div class="mt-10 text-center py-12 bg-white rounded-xl border border-dashed border-stone-300">
            <p class="text-stone-400 text-sm">More reviews coming soon</p>
          </div>
        </div>
        
        <aside class="space-y-8">
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h4 class="font-playfair text-lg font-medium mb-4">Popular in Haircare</h4>
            <ul class="space-y-3">
              {sidebarArticles.map(article => (
                <li><a href={article.href} class="text-sm text-stone-600 hover:text-sage-600 transition-colors leading-relaxed block">{article.title}</a></li>
              ))}
            </ul>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h4 class="font-playfair text-lg font-medium mb-4">Key Ingredients</h4>
            <div class="flex flex-wrap gap-2">
              {relatedIngredients.map(ing => <a href={ing.href} class="text-xs bg-sage-50 text-sage-700 px-3 py-1.5 rounded-full hover:bg-sage-100 transition-colors">{ing.name}</a>)}
            </div>
          </div>
          <div class="bg-sage-700 rounded-xl p-6 text-center">
            <h4 class="font-playfair text-white text-lg font-medium mb-2">Good Hair Days Ahead</h4>
            <p class="text-white/80 text-sm mb-4">Weekly vegan haircare tips, product picks, and ingredient guides.</p>
            <a href="/newsletter" class="inline-flex items-center justify-center py-2.5 px-5 w-full bg-white text-sage-700 font-semibold text-sm rounded-full hover:bg-sage-50 transition-all">Subscribe</a>
          </div>
        </aside>
      </div>
    </div>
  </section>
  
  <NewsletterForm variant="section" />
  <Footer />
</Layout>
