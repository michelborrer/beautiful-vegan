---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const pageTitle = 'Vegan Makeup Reviews | Beautiful Vegan';
const pageDescription = 'Pigment-rich, long-wearing vegan makeup reviews — foundations, lipsticks, mascaras, and more. All cruelty-free, all tested by real people.';

const breadcrumbItems = [
  { label: 'Reviews', href: '/reviews/makeup.html' },
  { label: 'Makeup' },
];

const articles = [
  {
    title: 'The Best Vegan Lipsticks That Actually Last All Day',
    excerpt: 'Tired of reapplying your lipstick every hour? These 6 vegan formulas stay put through coffee, lunch, and everything in between.',
    image: '/images/articles/lipstick-flatlay.jpg',
    category: 'Lipstick',
    categoryHref: '/reviews/makeup.html',
    href: '/reviews/makeup/best-vegan-lipsticks.html',
    date: 'May 10, 2025',
    readTime: '8 min read',
    rating: '4.7',
  },
  {
    title: 'Best Vegan Foundations for Every Skin Type',
    excerpt: 'Full coverage without the cruelty. We tested 18 vegan foundations to find the ones that blend seamlessly and last all day.',
    image: '/images/articles/foundation-review.jpg',
    category: 'Foundation',
    categoryHref: '/reviews/makeup.html',
    href: '/reviews/makeup/best-vegan-foundations.html',
    date: 'May 3, 2025',
    readTime: '11 min read',
    rating: '4.6',
  },
  {
    title: 'Vegan Makeup for Sensitive Eyes',
    excerpt: 'If you have sensitive eyes, finding vegan makeup that does not irritate can be challenging. These gentle formulas deliver beautiful results without the sting.',
    image: '/images/articles/eye-makeup-review.jpg',
    category: 'Eyes',
    categoryHref: '/reviews/makeup.html',
    href: '/reviews/makeup/vegan-makeup-sensitive-eyes.html',
    date: 'April 25, 2025',
    readTime: '9 min read',
    rating: '4.8',
  },
  {
    title: '6 Best Vegan Mascaras for Dramatic Lashes',
    excerpt: 'We tested 15 vegan mascaras to find the ones that deliver volume, length, and lasting power without smudging. Here are our top 6 picks.',
    image: '/images/articles/mascara-review.jpg',
    category: 'Mascara',
    categoryHref: '/reviews/makeup.html',
    href: '/reviews/makeup/best-vegan-mascaras.html',
    date: 'May 10, 2025',
    readTime: '10 min read',
    rating: '4.7',
  },
];

const sidebarArticles = [
  { title: 'Vegan Makeup for Sensitive Eyes', href: '/reviews/makeup/vegan-makeup-sensitive-eyes.html' },
  { title: 'Best Vegan Blushes for a Natural Flush', href: '/reviews/makeup/best-vegan-blushes.html' },
  { title: 'Is e.l.f. Really 100% Vegan?', href: '/brands/is-e-l-f--cruelty-free.html' },
];

const relatedIngredients = [
  { name: 'Avocado Oil', href: '/ingredients/avocado-for-skin.html' },
  { name: 'Jojoba Oil', href: '/ingredients/jojoba-oil-benefits.html' },
  { name: 'Coconut Oil', href: '/ingredients/coconut-oil-skin.html' },
];
---

<Layout title={pageTitle} description={pageDescription} canonical="/reviews/makeup.html">
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  
  <div class="bg-stone-50">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={breadcrumbItems} />
    </div>
  </div>
  
  <section class="relative bg-sage-900">
    <div class="absolute inset-0">
      <img src="/images/category-makeup.jpg" alt="Vegan makeup products on pink tray" class="w-full h-full object-cover opacity-30" loading="eager" width="1200" height="500" />
      <div class="absolute inset-0 bg-gradient-to-r from-sage-900/90 to-sage-900/50"></div>
    </div>
    <div class="container-main px-4 sm:px-6 lg:px-8 relative z-10 py-16 lg:py-24">
      <div class="max-w-2xl">
        <h1 class="text-white mb-4">Vegan Makeup Reviews</h1>
        <p class="text-sage-200 text-lg leading-relaxed">
          Pigment-rich, long-wearing vegan makeup that performs as good as it feels. From everyday essentials to bold statement looks, we test it all.
        </p>
      </div>
    </div>
  </section>
  
  <section class="bg-stone-50 section-padding">
    <div class="container-main px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_320px] gap-10">
        <div>
          <div class="flex flex-wrap items-center gap-3 mb-8">
            <span class="text-sm text-stone-500">Filter:</span>
            <a href="/reviews/makeup.html" class="px-4 py-1.5 bg-sage-500 text-white text-sm rounded-full font-medium">All</a>
            <a href="/reviews/makeup/best-vegan-foundations.html" class="px-4 py-1.5 bg-white text-stone-600 text-sm rounded-full font-medium border border-stone-200 hover:border-sage-300 transition-colors">Foundation</a>
            <a href="/reviews/makeup/best-vegan-lipsticks.html" class="px-4 py-1.5 bg-white text-stone-600 text-sm rounded-full font-medium border border-stone-200 hover:border-sage-300 transition-colors">Lipstick</a>
            <a href="/reviews/makeup/best-vegan-mascaras.html" class="px-4 py-1.5 bg-white text-stone-600 text-sm rounded-full font-medium border border-stone-200 hover:border-sage-300 transition-colors">Mascara</a>
            <a href="/reviews/makeup/best-vegan-blushes.html" class="px-4 py-1.5 bg-white text-stone-600 text-sm rounded-full font-medium border border-stone-200 hover:border-sage-300 transition-colors">Blush</a>
            <span class="px-4 py-1.5 bg-white text-stone-400 text-sm rounded-full font-medium border border-stone-200 opacity-50 cursor-not-allowed" title="Coming soon">Eyeshadow</span>
            <div class="ml-auto">
              <select class="bg-white border border-stone-200 rounded-lg px-3 py-1.5 text-sm text-stone-600 outline-none focus:border-sage-400">
                <option>Latest First</option>
                <option>Highest Rated</option>
              </select>
            </div>
          </div>
          
          <div class="grid sm:grid-cols-2 gap-6">
            {articles.map(article => <ArticleCard {...article} />)}
          </div>
          
          <div class="mt-10 text-center py-12 bg-white rounded-xl border border-dashed border-stone-300">
            <p class="text-stone-400 text-sm">More reviews coming soon</p>
          </div>
        </div>
        
        <aside class="space-y-8">
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h4 class="font-playfair text-lg font-medium mb-4">Popular in Makeup</h4>
            <ul class="space-y-3">
              {sidebarArticles.map(article => (
                <li><a href={article.href} class="text-sm text-stone-600 hover:text-sage-600 transition-colors leading-relaxed block">{article.title}</a></li>
              ))}
            </ul>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h4 class="font-playfair text-lg font-medium mb-4">Key Ingredients</h4>
            <div class="flex flex-wrap gap-2">
              {relatedIngredients.map(ing => <a href={ing.href} class="text-xs bg-sage-50 text-sage-700 px-3 py-1.5 rounded-full hover:bg-sage-100 transition-colors">{ing.name}</a>)}
            </div>
          </div>
          <div class="bg-sage-700 rounded-xl p-6 text-center">
            <h4 class="font-playfair text-white text-lg font-medium mb-2">New Reviews Weekly</h4>
            <p class="text-white/80 text-sm mb-4">Get the latest vegan makeup reviews delivered to your inbox.</p>
            <a href="/newsletter.html" class="inline-flex items-center justify-center py-2.5 px-5 w-full bg-white text-sage-700 font-semibold text-sm rounded-full hover:bg-sage-50 transition-all">Subscribe</a>
          </div>
        </aside>
      </div>
    </div>
  </section>
  
  <NewsletterForm variant="section" />
  <Footer />
</Layout>
