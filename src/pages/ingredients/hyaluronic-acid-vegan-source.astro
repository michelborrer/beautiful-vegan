---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const title = 'Hyaluronic Acid for Skin: Benefits & Best Products | Beautiful Vegan';
const description = 'The gold standard for hydration. Learn why this molecule can hold 1000x its weight in water and how to use it.';

const breadcrumbItems = [
  { label: 'Ingredients', href: '/ingredients/avocado-for-skin' },
  { label: 'Hyaluronic Acid' },
];

const faqQuestions = [{"q": "Is hyaluronic acid vegan?", "a": "Most modern hyaluronic acid is vegan — produced via bacterial fermentation rather than animal sources."}, {"q": "Should I apply hyaluronic acid to wet or dry skin?", "a": "Always apply to damp skin, then seal with moisturizer to prevent moisture loss."}, {"q": "Can I use hyaluronic acid with retinol?", "a": "Yes, they work well together. Apply hyaluronic acid after retinol to soothe and hydrate."}];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Hyaluronic Acid',
  description,
  author: { '@type': 'Person', name: 'Casey Bloom' },
  publisher: { '@type': 'Organization', name: 'Beautiful Vegan', logo: { '@type': 'ImageObject', url: 'https://beautiful-vegan.com/images/logo.png' } },
  datePublished: '2025-05-01',
  dateModified: '2026-06-18',
  mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://beautiful-vegan.com/ingredients/hyaluronic-acid-vegan-source' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqQuestions.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Layout title={title} description={description} canonical="/ingredients/hyaluronic-acid-vegan-source" schema={schema} author="Casey Bloom" image="/images/category-skincare.jpg">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Navigation />
  <div class="h-16 lg:h-18"></div>
  <div class="bg-stone-50"><div class="container-main px-4 sm:px-6 lg:px-8"><Breadcrumb items={breadcrumbItems} /></div></div>

  <section class="relative">
    <img src="/images/hero-avocado-ingredient.jpg" alt="Hyaluronic Acid for skincare" class="w-full aspect-[21/9] object-cover" loading="eager" width="1200" height="514" />
    <div class="absolute inset-0 bg-gradient-to-t from-stone-900/70 via-stone-900/30 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 container-main px-4 sm:px-6 lg:px-8 pb-8">
      <span class="tag-sage mb-3 inline-block">Ingredient Guide</span>
      <h1 class="text-white max-w-3xl font-playfair text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight">Hyaluronic Acid</h1>
      <div class="flex items-center gap-4 mt-4 text-white/70 text-sm">
        <span>By <strong class="text-white">Casey Bloom</strong></span><span>&middot;</span><span>Updated June 18, 2026</span><span>&middot;</span><span>10 min read</span>
      </div>
    </div>
  </section>

  <article class="bg-white">
    <div class="container-narrow px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <div class="text-lg text-stone-600 mb-8">
        <p class="text-xl leading-relaxed"><strong class="text-stone-900">Hyaluronic acid is the hydration hero every skin type needs.</strong></p>
        <p class="mt-4">This naturally occurring molecule in your skin can hold up to 1,000 times its weight in water, making it the ultimate hydrator. Vegan-sourced hyaluronic acid (fermented from plants) delivers the same results as animal-derived versions — without the cruelty.</p>
      </div>

      <h2>Key Benefits</h2>
      <ul class="space-y-3 mb-8 text-stone-600">
        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sage-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span><strong>Intense hydration</strong> — Holds 1000x its weight in water for plump, dewy skin.</span></li>
<li class="flex items-start gap-2"><svg class="w-5 h-5 text-sage-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span><strong>Plumps fine lines</strong> — Fills in dehydration lines for smoother skin texture.</span></li>
<li class="flex items-start gap-2"><svg class="w-5 h-5 text-sage-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span><strong>Suitable for all skin types</strong> — Non-irritating and works for sensitive, oily, and dry skin.</span></li>
<li class="flex items-start gap-2"><svg class="w-5 h-5 text-sage-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span><strong>Supports skin barrier</strong> — Helps maintain a healthy, hydrated protective layer.</span></li>

      </ul>

      <h2 class="mb-5">Frequently Asked Questions</h2>
      <div class="space-y-3 mb-10">
        {faqQuestions.map((faq, i) => (
          <details class="bg-stone-50 rounded-lg group" open={i === 0}>
            <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
              <span class="font-medium text-stone-900 pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-stone-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-4 pb-4"><p class="text-stone-600 leading-relaxed">{faq.a}</p></div>
          </details>
        ))}
      </div>

      <AuthorBox />
    </div>
  </article>

  <NewsletterForm variant="section" />
  <Footer />
</Layout>
