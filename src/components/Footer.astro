---
const currentYear = new Date().getFullYear();

const footerLinks = {
  about: [
    { label: 'Our Story', href: '/about.html' },
    { label: 'Contact', href: '/contact.html' },
    { label: 'Newsletter', href: '/newsletter.html' },
  ],
  categories: [
    { label: 'Skincare', href: '/reviews/skincare.html' },
    { label: 'Makeup', href: '/reviews/makeup.html' },
    { label: 'Haircare', href: '/reviews/haircare.html' },
    { label: 'Ingredients', href: '/ingredients/avocado-for-skin.html' },
    { label: 'Brands', href: '/brands.html' },
    { label: 'Guides', href: '/guides.html' },
  ],
  network: [
    { label: 'Vegan Tattoo Studios', href: 'https://vegantattoostudios.com', external: true, desc: 'Find cruelty-free tattoo studios worldwide' },
  ],
  legal: [
    { label: 'Privacy Policy', href: '/privacy-policy.html' },
    { label: 'Terms of Use', href: '/privacy-policy.html' },
    { label: 'Affiliate Disclosure', href: '/privacy-policy.html' },
  ],
  connect: [
    { label: 'Instagram', href: 'https://instagram.com/beautifulvegan', external: true },
    { label: 'Pinterest', href: 'https://pinterest.com/beautifulvegan', external: true },
  ],
};
---

<footer class="bg-sage-900 text-sage-100">
  <div class="container-main px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10 lg:gap-12">
      <!-- About -->
      <div>
        <h4 class="font-playfair text-lg font-semibold text-white mb-5">About</h4>
        <ul class="space-y-3">
          {footerLinks.about.map(link => (
            <li>
              <a 
                href={link.href}
                class="text-sage-300 hover:text-white transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Categories -->
      <div>
        <h4 class="font-playfair text-lg font-semibold text-white mb-5">Categories</h4>
        <ul class="space-y-3">
          {footerLinks.categories.map(link => (
            <li>
              <a 
                href={link.href}
                class="text-sage-300 hover:text-white transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Our Network -->
      <div>
        <h4 class="font-playfair text-lg font-semibold text-white mb-5">Our Network</h4>
        <ul class="space-y-3">
          {footerLinks.network.map(link => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener"
                class="text-sage-300 hover:text-white transition-colors text-sm"
              >
                {link.label}
              </a>
              {link.desc && <p class="text-xs text-sage-500 mt-1">{link.desc}</p>}
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-playfair text-lg font-semibold text-white mb-5">Legal</h4>
        <ul class="space-y-3">
          {footerLinks.legal.map(link => (
            <li>
              <a 
                href={link.href}
                class="text-sage-300 hover:text-white transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Connect -->
      <div>
        <h4 class="font-playfair text-lg font-semibold text-white mb-5">Follow Us</h4>
        <p class="text-sm text-sage-400 leading-relaxed mb-4">Coming soon.</p>
        <p class="mt-6 text-sm text-sage-400 leading-relaxed">
          Honest reviews of vegan and cruelty-free beauty products. Ethical beauty since 2009.
        </p>
      </div>
    </div>
  </div>
  
  <!-- Bottom Bar -->
  <div class="border-t border-sage-800">
    <div class="container-main px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-sage-400">
        &copy; {currentYear} Beautiful Vegan. All rights reserved.
      </p>
      <p class="text-sm text-sage-500 font-playfair italic">
        Ethical beauty since 2009
      </p>
    </div>
  </div>
</footer>
