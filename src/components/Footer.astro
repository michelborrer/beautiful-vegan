---
const currentYear = new Date().getFullYear();

const footerLinks = {
  about: [
    { label: 'Our Story', href: '/about' },
    { label: 'How We Test', href: '/how-we-test' },
    { label: 'Contact', href: '/contact' },
    { label: 'Newsletter', href: '/newsletter' },
  ],
  categories: [
    { label: 'Skincare', href: '/reviews/skincare' },
    { label: 'Makeup', href: '/reviews/makeup' },
    { label: 'Haircare', href: '/reviews/haircare' },
    { label: 'Ingredients', href: '/ingredients' },
    { label: 'Brands', href: '/brands' },
    { label: 'Guides', href: '/guides' },
  ],
  network: [
    { label: 'Vegan Tattoo Studios', href: 'https://vegantattoostudios.com', external: true, desc: 'Find cruelty-free tattoo studios worldwide' },
  ],
  legal: [
    { label: 'Privacy Policy', href: '/privacy-policy' },
    { label: 'Terms of Use', href: '/privacy-policy#terms' },
    { label: 'Affiliate Disclosure', href: '/privacy-policy#affiliate-disclosure' },
  ],
};
---

<footer class="bg-sage-900 text-sage-100">
  <div class="container-main px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10 lg:gap-12">
      <!-- About -->
      <div>
        <h4 class="font-playfair text-lg font-semibold text-white mb-5">About</h4>
        <ul class="space-y-3">
          {footerLinks.about.map(link => (
            <li>
              <a 
                href={link.href}
                class="text-sage-300 hover:text-white transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Categories -->
      <div>
        <h4 class="font-playfair text-lg font-semibold text-white mb-5">Categories</h4>
        <ul class="space-y-3">
          {footerLinks.categories.map(link => (
            <li>
              <a 
                href={link.href}
                class="text-sage-300 hover:text-white transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Our Network -->
      <div>
        <h4 class="font-playfair text-lg font-semibold text-white mb-5">Our Network</h4>
        <ul class="space-y-3">
          {footerLinks.network.map(link => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener"
                class="text-sage-300 hover:text-white transition-colors text-sm"
              >
                {link.label}
              </a>
              {link.desc && <p class="text-xs text-sage-500 mt-1">{link.desc}</p>}
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-playfair text-lg font-semibold text-white mb-5">Legal</h4>
        <ul class="space-y-3">
          {footerLinks.legal.map(link => (
            <li>
              <a 
                href={link.href}
                class="text-sage-300 hover:text-white transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Connect -->
      <div>
        <h4 class="font-playfair text-lg font-semibold text-white mb-5">Stay in Touch</h4>
        <p class="text-sm text-sage-400 leading-relaxed mb-4">
          The best way to follow along is the <a href="/newsletter" class="text-sage-300 hover:text-white underline transition-colors">newsletter</a> — one email a week, no fluff.
        </p>
        <a href="/rss.xml" class="inline-flex items-center gap-2 text-sm text-sage-300 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
          RSS feed
        </a>
      </div>
    </div>
  </div>
  
  <!-- Bottom Bar -->
  <div class="border-t border-sage-800">
    <div class="container-main px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-sage-400">
        &copy; {currentYear} Beautiful Vegan. All rights reserved.
      </p>
      <p class="text-sm text-sage-500 font-playfair italic">
        Ethical beauty since 2009
      </p>
    </div>
  </div>
</footer>
