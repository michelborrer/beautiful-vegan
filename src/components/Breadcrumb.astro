---
export interface Props {
  items: Array<{ label: string; href?: string }>;
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="py-4">
  <ol class="flex items-center flex-wrap gap-2 text-sm">
    <li>
      <a href="/" class="text-stone-500 hover:text-sage-600 transition-colors">Home</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-stone-300"><path d="m9 18 6-6-6-6"/></svg>
        {item.href ? (
          <a href={item.href} class="text-stone-500 hover:text-sage-600 transition-colors">{item.label}</a>
        ) : (
          <span class="text-stone-700 font-medium" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
