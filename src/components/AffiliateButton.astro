---
export interface Props {
  href?: string;
  label?: string;
}

const { href = '#', label = 'Check Price' } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer sponsored"
  class="inline-flex items-center gap-2 bg-rose-500 hover:bg-rose-600 text-white font-semibold text-sm py-2.5 px-5 rounded-full transition-colors"
>
  {label}
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
</a>
